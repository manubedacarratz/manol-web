---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  const lorem = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.';

  const projects = [
    { slug: 'aerolab',             title: 'AEROLAB',         year: '2024',      tags: ['Motion', 'Design'],
      descriptionEs: 'El reel 2024 de Aerolab es un video que presenta la nueva identidad visual del estudio junto con una selección de sus proyectos más destacados del año. Trabajé como diseñador y motion designer junto con Andrés Briganti, dándole forma y movimiento a la nueva identidad en una pieza audiovisual.',
      descriptionEn: 'Aerolab\'s 2024 reel is a video that showcases the studio\'s new visual identity alongside a selection of their most notable projects from the year. I worked as designer and motion designer alongside Andrés Briganti, bringing the new identity to life through motion.',
    },
    { slug: 'isla',                title: 'ISLA',             year: '2025',      tags: ['Motion', 'Design'],                     descriptionEn: lorem, descriptionEs: lorem },
    { slug: 'paisanos',            title: 'PAISANOS',         year: '2024',      tags: ['Motion'],
      descriptionEs: 'Paisanos es un estudio de tecnología y diseño que ayuda a empresas a transformar ideas en productos y modelos de negocio. Trabajé ahí durante dos años. En el 2024 desarrollamos la identidad gráfica y nueva web del estudio junto a un equipo interno. Mi rol fue de motion designer, enfocado principalmente en el sistema de animación del estudio. Trabajamos en conjunto con Camila Fumarola, Tatiana Vinci, Leonardo Suárez y Sebastián Bertolo.',
      descriptionEn: 'Paisanos is a technology and design studio that helps companies turn ideas into products and business models. I worked there for two years. In 2024, we developed the studio\'s new visual identity and website alongside an internal team. My role was motion designer, focused mainly on the studio\'s animation system. We worked together with Camila Fumarola, Tatiana Vinci, Leonardo Suárez and Sebastián Bertolo.',
    },
    { slug: 'from-room',           title: 'FROM ROOM',        year: '2026',      tags: ['Motion', 'Design'],                     descriptionEn: lorem, descriptionEs: lorem },
    { slug: 'reb',                 title: 'REB',              year: '2026',      tags: ['Branding'],
      descriptionEs: 'REB es una label de indumentaria urbana pensada como una reinterpretación contemporánea de la cultura del fútbol, con una referencia indirecta al CAI. Trabajamos la identidad completa: logo, sistema tipográfico, paleta y aplicaciones, junto con el desarrollo gráfico de las primeras prendas de la marca. Armamos un sistema que funcione de base para que la marca pueda expresarse a lo largo de los drops.',
      descriptionEn: 'REB is an urban clothing label conceived as a contemporary reinterpretation of football culture, with an indirect reference to CAI. We worked on the complete identity: logo, typographic system, color palette, and applications, along with the graphic development of the brand\'s first garments. We built a system flexible enough to serve as a foundation for the brand to express itself across future drops.',
      metaEs: 'Identidad de marca para REB, una label de indumentaria urbana con referencia a la cultura del fútbol. Logo, tipografía, paleta y aplicaciones.',
      metaEn: 'Brand identity for REB, an urban clothing label rooted in football culture. Logo, typographic system, color palette and applications.',
    },
    { slug: 'cass-guille-saporta', title: 'CASS & GUILLE',    year: '2025',      tags: ['Film', 'Design'],                       descriptionEn: lorem, descriptionEs: lorem },
    { slug: 'bernardo-parisi',     title: 'BERNARDO PARISI',  year: '2025',      tags: ['Art Cover', 'Art Direction'],
      descriptionEs: 'Trabajamos en el lanzamiento de "La motito", el nuevo disco de Bernardo Parisi. El proyecto incluyó el arte de tapa y contratapa, además de las piezas de comunicación para el lanzamiento y la fecha de presentación. El disco está disponible en todas las plataformas.',
      descriptionEn: 'We worked on the launch of "La motito", Bernardo Parisi\'s new album. The project included the cover and back cover art, along with the communication pieces for the release and presentation date. The album is now available on all platforms.',
      metaEs: 'Arte de tapa y comunicación de lanzamiento para "La motito", el nuevo disco de Bernardo Parisi.',
      metaEn: 'Cover art and release communication for "La motito", Bernardo Parisi\'s new album.',
    },
    { slug: 'montanas',            title: 'MONTAÑAS',         year: '2023',      tags: ['Art Cover', 'Art Direction', 'Motion'], descriptionEn: lorem, descriptionEs: lorem },
    { slug: 'legado',              title: 'LEGADO',           year: '2025–2026', tags: ['Branding'],
      descriptionEs: 'Legado es una obra de danza contemporánea que se sumerge en la herencia para construir una pieza que es confesión y manifiesto. La rotura, la caricia, el golpe, el gesto heredado, el grito silencioso y la voz inminente. La concentración de lo vivo y lo muerto en el cuerpo insurgente de la mujer que obedece. Trabajamos en la identidad y la comunicación de la obra junto con Mireya Ponce.',
      descriptionEn: 'Legado is a contemporary dance piece that delves into inheritance to build a work that is both confession and manifesto. The rupture, the caress, the blow, the inherited gesture, the silent scream, the imminent voice, the concentration of the living and the dead in the insurgent body of the woman who obeys. We worked on the identity and communication of the piece together with Mireya Ponce.',
    },
    { slug: 'cafe-vilma',          title: 'CAFE VILMA',       year: '2026',      tags: ['Branding', 'Motion'],
      descriptionEs: 'Vilma es un café ubicado en un antiguo puesto de diarios de Buenos Aires, pensado como una reinterpretación de los cafés tradicionales. Junto con Justina Antonacci trabajamos la identidad completa del local: desde el logo y el sistema tipográfico hasta el packaging y la cartelería del puesto. El concepto pone el foco en la barra como espacio de encuentro, en la calidez de lo cotidiano y en la dimensión social del café de paso.',
      descriptionEn: 'Vilma is a café set in a former newsstand in Buenos Aires, conceived as a reinterpretation of traditional cafés. Together with Justina Antonacci, we developed the brand\'s full identity: from the logo and typographic system to packaging and signage for the stand. The concept centers on the counter as a meeting point, the warmth of everyday routine, and the social dimension of a quick coffee stop.',
      metaEs: 'Identidad de marca para Vilma, un café en un antiguo puesto de diarios de Buenos Aires. Logo, tipografía, packaging y cartelería.',
      metaEn: 'Brand identity for Vilma, a café in a former newsstand in Buenos Aires. Logo, typography, packaging and signage.',
    },
  ];
  return projects.map(p => ({ params: { slug: p.slug }, props: p }));
}

const { slug, title, year, tags, descriptionEn, descriptionEs, metaEn, metaEs } = Astro.props;

const allProjects = [
  { slug: 'aerolab',             title: 'AEROLAB',         year: '2024',      cover: '/work/aerolab.jpg'             },
  { slug: 'isla',                title: 'ISLA',             year: '2025',      cover: '/work/isla.jpg'                },
  { slug: 'paisanos',            title: 'PAISANOS',         year: '2024',      cover: '/work/paisanos.jpg'            },
  { slug: 'from-room',           title: 'FROM ROOM',        year: '2026',      cover: '/work/from-room.jpg'           },
  { slug: 'reb',                 title: 'REB',              year: '2026',      cover: '/work/reb.jpg'                 },
  { slug: 'cass-guille-saporta', title: 'CASS & GUILLE',    year: '2025',      cover: '/work/cass-guille-saporta.jpg' },
  { slug: 'bernardo-parisi',     title: 'BERNARDO PARISI',  year: '2025',      cover: '/work/bernardo-parisi.jpg'    },
  { slug: 'montanas',            title: 'MONTAÑAS',         year: '2023',      cover: '/work/montanas.jpg'            },
  { slug: 'legado',              title: 'LEGADO',           year: '2025–2026', cover: '/work/legado.jpg'              },
  { slug: 'cafe-vilma',          title: 'CAFE VILMA',       year: '2026',      cover: '/work/cafe-vilma.jpg'          },
];

const soonSlugs = new Set(['from-room', 'cass-guille-saporta', 'isla', 'montanas']);

const suggestions = allProjects
  .filter(p => p.slug !== slug && !soonSlugs.has(p.slug))
  .sort(() => Math.random() - 0.5)
  .slice(0, 4);
