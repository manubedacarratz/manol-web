---
interface Props {
  color?: string;
}
const { color = 'var(--color-text)' } = Astro.props;
---

<div class="overflow-hidden border-b border-[var(--color-border)]" style="padding: 0 20px;">
  <div
    class="fit-text font-black leading-none whitespace-nowrap select-none"
    style={`font-family: 'Jaro', sans-serif; letter-spacing: -0.1em; color: ${color}; display: block; width: 100%;`}
    aria-hidden="true"
  >
    MANOL
  </div>
</div>

<script>
  import { initFitText } from '../scripts/fitText.js';
  initFitText();
</script>
