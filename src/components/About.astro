---
const clients = [
  { name: 'Paisanos', url: 'https://www.paisanos.io/es' },
  { name: 'Aerolab', url: 'https://aerolab.co/' },
  { name: 'Paradigma', url: 'https://paradigma.cc/' },
  { name: 'Rampant', url: 'https://www.rampant.work/' },
  { name: 'Joyco', url: 'https://joyco.studio/' },
  { name: 'Almanach', url: 'https://almanach.work/' },
];

const tools = ['After Effects', 'DaVinci Resolve', 'Figma', 'Illustrator', 'Photoshop'];
---

<section id="about" class="px-6 md:px-10 py-24 border-t border-[var(--color-accent)]/30">
  <div class="grid md:grid-cols-2 gap-16 max-w-5xl">
    <div>
      <h2 class="text-xs tracking-widest uppercase text-[var(--color-muted)] mb-10">About</h2>
      <p class="text-2xl font-light leading-[0.65] mb-8">
        Soy Manu, diseñador gráfico especializado en motion design.
        Trabajo de forma independiente desde Buenos Aires para estudios,
        marcas y proyectos culturales alrededor del mundo.
      </p>
      <p class="text-sm text-[var(--color-muted)] leading-[0.65]">
        Nueve años de diseño, siete en motion. Trabajo solo o en colaboración
        con equipos cuando el proyecto lo pide. Me interesa hacer animaciones
        que tengan algo artesanal — que parezcan hechas a mano, no solo
        llamativas.
      </p>
    </div>

    <div class="space-y-12">
      <div>
        <p class="text-xs tracking-widest uppercase text-[var(--color-muted)] mb-4">Herramientas</p>
        <div class="flex flex-wrap gap-2">
          {tools.map(tool => (
            <span class="text-sm border border-[var(--color-accent)]/40 px-3 py-1 rounded-full">
              {tool}
            </span>
          ))}
        </div>
      </div>

      <div>
        <p class="text-xs tracking-widest uppercase text-[var(--color-muted)] mb-4">Han confiado</p>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          {clients.map(client => (
            <a
              href={client.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm hover:opacity-60 transition-opacity"
            >
              {client.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
