---
import { musicData } from '../data/music.js';
---

<!-- Video full frame -->
<section id="hero-section" class="pt-[20px]" style="padding-left: 20px; padding-right: 20px;">
  <div id="hero-video-wrap" style="padding:56.24% 0 0 0;position:relative;border-radius:8px;overflow:hidden;">
    <video
      id="hero-video"
      src="/reel-2026.mp4"
      autoplay
      loop
      muted
      playsinline
      style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;"
    ></video>

    <button
      id="sound-toggle"
      aria-label="Toggle sound"
      style="position:absolute;bottom:12px;right:12px;z-index:10;background:rgba(20,20,20,0.65);border:1px solid rgba(212,207,201,0.12);border-radius:6px;padding:8px;cursor:none;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(6px);"
    >
      <svg id="icon-muted" width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path d="M11 5L6 9H2v6h4l5 4V5z" fill="#d4cfc9"/>
        <line x1="15" y1="9" x2="21" y2="15" stroke="#d4cfc9" stroke-width="2" stroke-linecap="round"/>
        <line x1="21" y1="9" x2="15" y2="15" stroke="#d4cfc9" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-sound" width="16" height="16" viewBox="0 0 24 24" fill="none" style="display:none;">
        <path d="M11 5L6 9H2v6h4l5 4V5z" fill="#d4cfc9"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="#d4cfc9" stroke-width="2" stroke-linecap="round" fill="none"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14" stroke="#d4cfc9" stroke-width="2" stroke-linecap="round" fill="none"/>
      </svg>
    </button>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    #hero-section {
      padding: 0 !important;
    }
    #hero-video-wrap {
      padding: 0 !important;
      aspect-ratio: 4 / 5;
      border-radius: 0 !important;
    }
    #hero-video-wrap video {
      position: relative !important;
      width: 100% !important;
      height: 100% !important;
    }
    #manol-img {
      margin-top: 0 !important;
      margin-bottom: 0 !important;
    }
  }

  @keyframes vinyl-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .vinyl-record {
    animation: vinyl-spin 3s linear infinite;
    display: block;
  }

</style>

<!-- MANOL wordmark -->
<div style="padding: 0;">
  <div id="manol-wrap" style="overflow: hidden;">
    <img
      id="manol-img"
      src="/footer/manol.png"
      alt="MANOL"
      style="width: 100%; height: auto; display: block; opacity: 0.2; margin-top: -50px; margin-bottom: -50px;"
    />
  </div>
</div>

<!-- Info row -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-8" style="padding: 12px 20px;">

  <div class="max-w-sm">
    <div class="lang-en">
      <p class="text-xs text-[var(--color-muted)] leading-relaxed">
        My name is Manu Bedacarratz, but most people call me Manol. Graphic and motion designer based in Buenos Aires. I work alongside friends and colleagues across all kinds of projects — from brand identities and motion systems to posters and music videos.
      </p>
    </div>
    <div class="lang-es">
      <p class="text-xs text-[var(--color-muted)] leading-relaxed">
        Mi nombre es Manu Bedacarratz, también me dicen Manol. Diseñador gráfico y de motion basado en Buenos Aires. Trabajo junto con amigos y colegas en todo tipo de proyectos: desde identidades y sistemas de animación hasta posters o videoclips.
      </p>
    </div>
  </div>

  <div class="flex flex-col items-end justify-between">
    <div class="text-right space-y-1">
      <p class="text-xs text-[var(--color-muted)]">Based in Buenos Aires,</p>
      <p class="text-xs text-[var(--color-muted)]">Working worldwide</p>
    </div>
    <a
      id="music-link"
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 group cursor-none"
    >
      <p class="text-xs text-[var(--color-muted)] group-hover:text-[var(--color-text)] transition-colors">
        Currently listening
      </p>
      <div class="flex-none" style="width:40px;height:40px;">
        <svg viewBox="0 0 40 40" width="40" height="40" class="vinyl-record">
          <circle cx="20" cy="20" r="19" fill="#1c1c1a"/>
          <circle cx="20" cy="20" r="17"   fill="none" stroke="#232320" stroke-width="0.8"/>
          <circle cx="20" cy="20" r="14.5" fill="none" stroke="#232320" stroke-width="0.8"/>
          <circle cx="20" cy="20" r="12"   fill="none" stroke="#232320" stroke-width="0.8"/>
          <circle cx="20" cy="20" r="9.5"  fill="none" stroke="#232320" stroke-width="0.8"/>
          <circle cx="20" cy="20" r="7" fill="#2e2820"/>
          <circle cx="20" cy="20" r="1.5" fill="#141414"/>
        </svg>
      </div>
    </a>
  </div>

</div>


<script>
  import { tracks } from '../data/music.js';

  const musicLink = document.getElementById('music-link') as HTMLAnchorElement;
  function pickTrack() {
    musicLink.href = tracks[Math.floor(Math.random() * tracks.length)];
  }
  pickTrack();
  setInterval(pickTrack, 30_000);


  // Sound toggle
  const soundBtn  = document.getElementById('sound-toggle');
  const iconMuted = document.getElementById('icon-muted');
  const iconSound = document.getElementById('icon-sound');
  const video     = document.getElementById('hero-video') as HTMLVideoElement;

  soundBtn?.addEventListener('click', () => {
    video.muted = !video.muted;
    iconMuted!.style.display = video.muted ? '' : 'none';
    iconSound!.style.display = video.muted ? 'none' : '';
  });
</script>
