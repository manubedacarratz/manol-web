---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between" style="padding-top: 32px; padding-bottom: 20px; padding-left: 32px; padding-right: 32px;">
  <a href="/" id="nav-logo-link" class="flex items-center">
    <span id="nav-logo-text" class="text-xs tracking-widest uppercase font-medium text-[var(--color-text)]">manol</span>
    <canvas id="nav-logo-canvas" style="height: 12px; width: auto; display: none;"></canvas>
  </a>
  <div class="flex items-center" id="nav-right">
    <div class="flex items-center" id="nav-links">
      <a href="/#work"    class="lang-en text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Work</a>
      <a href="/#work"    class="lang-es text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Trabajo</a>
      <a href="/#archive" class="lang-en text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Archive</a>
      <a href="/#archive" class="lang-es text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Archivo</a>
      <a href="/#about"   class="lang-en text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">About</a>
      <a href="/#about"   class="lang-es text-xs tracking-widest uppercase text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">Sobre mí</a>
    </div>
    <button id="nav-menu-toggle" aria-label="Toggle menu">Menu</button>
  </div>
</nav>

<style>
  #nav-links {
    gap: 32px;
  }

  #nav-menu-toggle {
    display: none;
  }

  @media (max-width: 767px) {
    #nav-links {
      gap: 20px;
      overflow: hidden;
      max-width: 0;
      opacity: 0;
      pointer-events: none;
      transition: max-width 0.35s ease, opacity 0.25s ease;
      white-space: nowrap;
    }

    #nav-links.open {
      max-width: 400px;
      opacity: 1;
      pointer-events: auto;
    }

    #nav-menu-toggle {
      display: block;
      background: none;
      border: none;
      font-family: 'Geist Mono', 'Courier New', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted);
      padding: 0;
      margin-left: 20px;
      cursor: pointer;
      transition: color 0.15s ease;
      flex-shrink: 0;
    }

    #nav-menu-toggle:hover,
    #nav-menu-toggle.open {
      color: var(--color-text);
    }
  }
</style>

<script>
  function applyTheme(theme: string) {
    document.documentElement.classList.toggle('light', theme === 'light');
    document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach(btn => {
      const active = btn.dataset.theme === theme;
      btn.style.background = active ? 'var(--color-text)' : 'transparent';
      btn.style.color      = active ? 'var(--color-bg)'   : 'var(--color-muted)';
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach(btn => {
    btn.addEventListener('click', () => applyTheme(btn.dataset.theme!));
  });

  applyTheme('dark');
</script>

<script>
  function easeInOutCubic(t: number) {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
  }

  function smoothScrollTo(target: HTMLElement, duration = 800) {
    const startY = window.scrollY;
    const endY   = startY + target.getBoundingClientRect().top;
    const startTime = performance.now();

    function step(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      window.scrollTo(0, startY + (endY - startY) * easeInOutCubic(progress));
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  document.querySelectorAll<HTMLAnchorElement>('nav a[href*="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const [path, id] = link.getAttribute('href')!.split('#');
      if (path && path !== window.location.pathname) return;
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      smoothScrollTo(target);
      history.pushState(null, '', `#${id}`);
    });
  });
</script>

<script>
  import { parseGIF, decompressFrames } from 'gifuct-js';

  const link    = document.getElementById('nav-logo-link') as HTMLAnchorElement;
  const text    = document.getElementById('nav-logo-text') as HTMLSpanElement;
  const canvas  = document.getElementById('nav-logo-canvas') as HTMLCanvasElement;
  const ctx     = canvas.getContext('2d')!;

  const SPEED = 1.5;
  let frames: ReturnType<typeof decompressFrames> = [];
  let frameIndex = 0;
  let timer: ReturnType<typeof setTimeout> | null = null;
  let loaded = false;

  async function loadGif() {
    const res    = await fetch('/footer/manol.gif');
    const buffer = await res.arrayBuffer();
    const gif    = parseGIF(buffer);
    frames       = decompressFrames(gif, true);

    // set canvas to natural GIF dimensions, CSS scales it to 12px height
    canvas.width  = frames[0].dims.width;
    canvas.height = frames[0].dims.height;
    loaded = true;
  }

  function drawFrame(index: number) {
    const f = frames[index];
    const imageData = new ImageData(f.patch, f.dims.width, f.dims.height);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.putImageData(imageData, f.dims.left, f.dims.top);

    const delay = (f.delay || 10) / SPEED;
    timer = setTimeout(() => {
      frameIndex = (index + 1) % frames.length;
      drawFrame(frameIndex);
    }, delay);
  }

  function startGif() {
    if (!loaded) return;
    frameIndex = 0;
    drawFrame(frameIndex);
  }

  function stopGif() {
    if (timer) { clearTimeout(timer); timer = null; }
    ctx.clearRect(0, 0, canvas.width, canvas.height);
  }

  link.addEventListener('mouseenter', () => {
    text.style.display   = 'none';
    canvas.style.display = 'block';
    startGif();
  });

  link.addEventListener('mouseleave', () => {
    stopGif();
    canvas.style.display = 'none';
    text.style.display   = '';
  });

  // preload en background para que el primer hover no tenga delay
  loadGif();
</script>

<script>
  const toggle   = document.getElementById('nav-menu-toggle')!;
  const navLinks = document.getElementById('nav-links')!;

  toggle.addEventListener('click', () => {
    const isOpen = navLinks.classList.toggle('open');
    toggle.classList.toggle('open', isOpen);
    toggle.textContent = isOpen ? 'Close' : 'Menu';
  });

  // Cerrar al tocar un link
  navLinks.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks.classList.remove('open');
      toggle.classList.remove('open');
      toggle.textContent = 'Menu';
    });
  });
</script>
